# =====================================================
# GEMINI API — Used for LLM responses + audio only
# Embeddings + NLP now run locally via Xenova (free)
# =====================================================
DATABASE_URL=postgresql://username:password@your-neon-host/your-database?sslmode=verify-full
JWT_SECRET=replace-with-a-long-random-secret
GEMINI_API_KEY=replace-with-your-google-gemini-api-key

# Local Model Settings
XENOVA_CACHE_DIR=./models_cache
NODE_ENV=development

AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=rag-documents
PORT=5000
